                    android:offset="0.0" />
                <item
                    android:color="#FF9800"
                    android:offset="1.0" />
            </gradient>
        </aapt:attr>
    </path>

    <!-- Star on highlighted square (shows it's a special event) - perfectly centered at (54, 70.5) -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M54,69.2 L54.3,70.1 L55.2,70.2 L54.5,70.9 L54.7,71.8 L54,71.4 L53.3,71.8 L53.5,70.9 L52.8,70.2 L53.7,70.1 Z" />

    <!-- Subtle shine on calendar body -->
    <path
        android:fillColor="#08FFFFFF"
        android:pathData="M36,50h36v10H36z" />

</vector>