                android:startY="40"
                android:type="linear">
                <item
                    android:color="#1976D2"
                    android:offset="0.0" />
                <item
                    android:color="#1565C0"
                    android:offset="1.0" />
            </gradient>
        </aapt:attr>
    </path>

    <!-- Highlight on top of header -->
    <path
        android:fillColor="#33FFFFFF"
        android:pathData="M36,40h36c3,0 5.5,2.5 5.5,5.5v1H30.5v-1c0,-3 2.5,-5.5 5.5,-5.5z" />

    <!-- Calendar rings/hangers (2 rings on top) with shadow -->
    <path
        android:pathData="M43,36v8 M65,36v8"
        android:strokeWidth="3.5"
        android:strokeColor="#E0E0E0"
        android:strokeLineCap="round" />
    <path
        android:pathData="M43,36v8 M65,36v8"
        android:strokeWidth="3"
        android:strokeColor="#FFFFFF"
        android:strokeLineCap="round" />

    <!-- Grid of squares (3x3 layout) - centered -->
    <!-- Row 1 -->
    <path
        android:fillColor="#90CAF9"
        android:pathData="M40,54h5v5h-5z M51.5,54h5v5h-5z M63,54h5v5h-5z" />

    <!-- Row 2 -->
    <path
        android:fillColor="#90CAF9"
        android:pathData="M40,61h5v5h-5z M51.5,61h5v5h-5z M63,61h5v5h-5z" />

    <!-- Row 3 - with one highlighted square -->
    <path
        android:fillColor="#90CAF9"
        android:pathData="M40,68h5v5h-5z M63,68h5v5h-5z" />

    <!-- Highlighted square (accent - event marker) with gradient -->
    <path android:pathData="M51.5,68h5v5h-5z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:endY="73"
                android:startY="68"
                android:type="linear">
                <item
