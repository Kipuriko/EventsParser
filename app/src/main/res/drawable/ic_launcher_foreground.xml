<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- Background circle with gradient -->
    <path android:pathData="M54,54m-48,0a48,48 0,1 1,96 0a48,48 0,1 1,-96 0">
        <aapt:attr name="android:fillColor">
            <gradient
                android:endX="54"
                android:endY="98"
                android:startX="54"
                android:startY="10"
                android:type="linear">
                <item
                    android:color="#42A5F5"
                    android:offset="0.0" />
                <item
                    android:color="#1E88E5"
                    android:offset="1.0" />
            </gradient>
        </aapt:attr>
    </path>

    <!-- Shadow under calendar -->
    <path
        android:fillColor="#1A000000"
        android:pathData="M36,73h36c3,0 5.5,2.5 5.5,5.5c0,0 -2,2 -5.5,2H36c-3.5,0 -5.5,-2 -5.5,-2c0,-3 2.5,-5.5 5.5,-5.5z" />

    <!-- Calendar body (white background) -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M36,40h36c3,0 5.5,2.5 5.5,5.5v24c0,3 -2.5,5.5 -5.5,5.5H36c-3,0 -5.5,-2.5 -5.5,-5.5v-24c0,-3 2.5,-5.5 5.5,-5.5z" />

    <!-- Calendar header with gradient -->
